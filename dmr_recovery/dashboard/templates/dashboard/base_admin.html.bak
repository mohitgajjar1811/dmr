<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Dashboard | Virja Admin{% endblock %}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        /* Custom Scrollbar Styling */
        ::-webkit-scrollbar {
            width: 5px;
            height: 5px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: rgba(156, 163, 175, 0.3);
            border-radius: 20px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: rgba(107, 114, 128, 0.5);
        }

        /* Specific for Sidebar to match dark theme */
        aside::-webkit-scrollbar-thumb,
        aside *::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
        }

        aside::-webkit-scrollbar-thumb:hover,
        aside *::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        /* Firefox Support */
        * {
            scrollbar-width: thin;
            scrollbar-color: rgba(156, 163, 175, 0.3) transparent;
        }
    </style>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.13.3/dist/cdn.min.js"></script>
    {% block extra_head %}{% endblock %}
</head>

<body class="bg-gray-100 text-gray-800 font-sans antialiased" x-data="{ sidebarOpen: false }">

    <div class="flex h-screen overflow-hidden">
        <!-- Overlay -->
        <div x-show="sidebarOpen" @click="sidebarOpen = false"
            x-transition:enter="transition-opacity ease-linear duration-300" x-transition:enter-start="opacity-0"
            x-transition:enter-end="opacity-100" x-transition:leave="transition-opacity ease-linear duration-300"
            x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
            class="fixed inset-0 bg-black bg-opacity-50 z-20 md:hidden"></div>

        <!-- Sidebar -->
        <aside :class="sidebarOpen ? 'translate-x-0' : '-translate-x-full'"
            class="fixed inset-y-0 left-0 z-30 w-64 bg-gray-900 text-white flex flex-col shadow-xl transition-transform duration-300 transform md:translate-x-0 md:static md:inset-auto">
            <div class="h-16 flex items-center justify-center border-b border-gray-800">
                <h1 class="text-xl font-bold tracking-wider text-white">VIRJA <span class="text-red-500">ADMIN</span>
                </h1>
                <!-- Mobile Close Button -->
                <button @click="sidebarOpen = false" class="md:hidden absolute right-4 text-gray-400 hover:text-white">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <nav class="flex-1 overflow-y-auto py-4">
                <ul class="space-y-1 px-2">
                    <li>
                        <a href="{% url 'dashboard:home' %}"
                            class="flex items-center gap-3 px-4 py-3 rounded hover:bg-gray-800 transition {% if request.resolver_match.url_name == 'home' %}bg-gray-800 border-l-4 border-red-500{% endif %}">
                            <i class="fas fa-tachometer-alt w-5 text-center"></i>
                            <span class="font-medium">Dashboard</span>
                        </a>
                    </li>
                    <li class="pt-4 pb-2 px-4 text-xs font-bold text-gray-500 uppercase tracking-widest">Catalog</li>
                    <li>
                        <a href="{% url 'dashboard:product_list' %}"
                            class="flex items-center gap-3 px-4 py-3 rounded hover:bg-gray-800 transition text-gray-300 hover:text-white {% if 'product' in request.resolver_match.url_name %}bg-gray-800 text-white{% endif %}">
                            <i class="fas fa-box w-5 text-center"></i>
                            <span class="font-medium">Products</span>
                        </a>
                    </li>
                    <li>
                        <a href="{% url 'dashboard:category_list' %}"
                            class="flex items-center gap-3 px-4 py-3 rounded hover:bg-gray-800 transition text-gray-300 hover:text-white {% if request.resolver_match.url_name == 'category_list' %}bg-gray-800 text-white{% endif %}">
                            <i class="fas fa-folder w-5 text-center"></i>
                            <span class="font-medium">Categories</span>
                        </a>
                    </li>
                    <li>
                        <a href="{% url 'dashboard:brand_list' %}"
                            class="flex items-center gap-3 px-4 py-3 rounded hover:bg-gray-800 transition text-gray-300 hover:text-white {% if request.resolver_match.url_name == 'brand_list' %}bg-gray-800 text-white{% endif %}">
                            <i class="fas fa-tags w-5 text-center"></i>
                            <span class="font-medium">Brands</span>
                        </a>
                    </li>
                    <li>
                        <a href="{% url 'dashboard:enquiry_list' %}"
                            class="flex items-center gap-3 px-4 py-3 rounded hover:bg-gray-800 transition text-gray-300 hover:text-white {% if 'enquiry' in request.resolver_match.url_name %}bg-gray-800 text-white{% endif %}">
                            <i class="fas fa-envelope w-5 text-center"></i>
                            <span class="font-medium">Enquiries</span>
                        </a>
                    </li>
                    <li>
                        <a href="{% url 'dashboard:newsletter_list' %}"
                            class="flex items-center gap-3 px-4 py-3 rounded hover:bg-gray-800 transition text-gray-300 hover:text-white {% if 'newsletter' in request.resolver_match.url_name %}bg-gray-800 text-white{% endif %}">
                            <i class="fas fa-paper-plane w-5 text-center"></i>
                            <span class="font-medium">Newsletter</span>
                        </a>
                    </li>

                    <li class="pt-4 pb-2 px-4 text-xs font-bold text-gray-500 uppercase tracking-widest">Content
                        Management</li>
                    <li>
                        <a href="{% url 'dashboard:site_settings' %}"
                            class="flex items-center gap-3 px-4 py-3 rounded hover:bg-gray-800 transition text-gray-300 hover:text-white {% if request.resolver_match.url_name == 'site_settings' %}bg-gray-800 text-white{% endif %}">
                            <i class="fas fa-cogs w-5 text-center"></i>
                            <span class="font-medium">Site Settings</span>
                        </a>
                    </li>
                    <li>
                        <a href="{% url 'dashboard:home_content' %}"
                            class="flex items-center gap-3 px-4 py-3 rounded hover:bg-gray-800 transition text-gray-300 hover:text-white {% if request.resolver_match.url_name == 'home_content' %}bg-gray-800 text-white{% endif %}">
                            <i class="fas fa-home w-5 text-center"></i>
                            <span class="font-medium">Home Page</span>
                        </a>
                    </li>
                    <li>
                        <a href="{% url 'dashboard:smtp_settings' %}"
                            class="flex items-center gap-3 px-4 py-3 rounded hover:bg-gray-800 transition text-gray-300 hover:text-white {% if request.resolver_match.url_name == 'smtp_settings' %}bg-gray-800 text-white{% endif %}">
                            <i class="fas fa-paper-plane w-5 text-center"></i>
                            <span class="font-medium">SMTP Settings</span>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="p-4 border-t border-gray-800">
                <a href="{% url 'dashboard:logout' %}"
                    class="flex items-center gap-3 px-4 py-2 rounded text-gray-400 hover:text-white hover:bg-red-900/50 transition">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Logout</span>
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <div class="flex-1 flex flex-col overflow-hidden">
            <!-- Top Header -->
            <header class="h-16 bg-white shadow-sm flex items-center justify-between px-6 z-10">
                <div class="text-gray-500">
                    <button @click="sidebarOpen = !sidebarOpen"
                        class="focus:outline-none md:hidden text-xl hover:text-gray-800">
                        <i class="fas fa-bars"></i>
                    </button>
                    <!-- Desktop Menu Trigger (if needed) -->
                    <i class="fas fa-bars cursor-pointer text-xl hover:text-gray-800 hidden md:block"></i>
                </div>
                <div class="flex items-center gap-4">
                    <span class="text-sm font-medium text-gray-600">Welcome, {{ request.user.username }}</span>
                    <div
                        class="w-8 h-8 rounded-full bg-gray-200 flex items-center justify-center text-gray-500 font-bold">
                        {{ request.user.username|make_list|first|upper }}
                    </div>
                </div>
            </header>

            <!-- Main Area -->
            <main class="flex-1 overflow-x-hidden overflow-y-auto bg-gray-100 p-6">
                {% if messages %}
                <div class="mb-6 space-y-2">
                    {% for message in messages %}
                    <div
                        class="p-4 rounded shadow-sm border-l-4
                                {% if message.tags == 'error' %}bg-red-50 border-red-500 text-red-700{% else %}bg-green-50 border-green-500 text-green-700{% endif %}">
                        {{ message }}
                    </div>
                    {% endfor %}
                </div>
                {% endif %}

                {% block content %}{% endblock %}
            </main>
        </div>
    </div>

</body>

</html>