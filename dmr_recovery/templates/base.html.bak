{% load static %}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ company_info.name|default:"Virja Industries" }}{% endblock %}</title>
    <!-- Tailwind CSS (CDN for development, replace with local build in production) -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#1a365d', /* Navy Blue */
                        secondary: '#c53030', /* Industrial Red */
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    keyframes: {
                        marquee: {
                            '0%': { transform: 'translateX(0)' },
                            '100%': { transform: 'translateX(-50%)' },
                        }
                    },
                    animation: {
                        marquee: 'marquee 30s linear infinite',
                    }
                }
            }
        }
    </script>
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700;900&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
        }

        [x-cloak] {
            display: none !important;
        }

        .text-shadow-md {
            text-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }

        .bg-pattern {
            background-image: radial-gradient(#ffffff 1px, transparent 1px);
            background-size: 20px 20px;
        }
    </style>
</head>

<body class="flex flex-col min-h-screen bg-gray-50 text-gray-800">

    <!-- Header & Navigation -->
    <header class="bg-white shadow-md relative z-50 sticky top-0" x-data="{ mobileMenuOpen: false }">
        <!-- Main Header Row -->
        <div class="container mx-auto px-4 py-3 flex justify-between items-center bg-white relative z-20">
            <!-- Logo -->
            <a href="{% url 'home' %}" class="flex items-center gap-2 group ml-12">
                {% if company_info.logo %}
                <img src="{{ company_info.logo.url }}" alt="{{ company_info.name }}" class="h-16 w-auto object-contain">
                {% else %}
                <img src="{% static 'img/virja_logo.png' %}" alt="Virja Automation Pvt. Ltd."
                    class="h-16 w-auto object-contain">
                {% endif %}
            </a>

            <!-- Search Bar (Desktop) -->
            <div class="hidden md:block flex-1 max-w-2xl mx-4 lg:mx-8">
                <form action="{% url 'product_list' %}" method="GET" class="flex w-full relative group">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fas fa-search text-gray-400 group-focus-within:text-primary transition-colors"></i>
                    </div>
                    <input type="text" name="q" placeholder="Search products (e.g. 'Carbide', 'Gloves')..."
                        class="w-full border-2 border-gray-100 bg-gray-50 rounded-md pl-10 pr-4 py-2.5 focus:outline-none focus:border-primary focus:bg-white transition-all text-sm font-medium text-gray-700 placeholder-gray-400 shadow-inner">
                    <button type="submit"
                        class="absolute right-1 top-1 bottom-1 bg-white text-primary font-bold px-4 rounded hover:bg-gray-100 transition text-xs uppercase tracking-wide border border-gray-100">
                        Find
                    </button>
                </form>
            </div>

            <!-- CTA & Contact -->
            <div class="hidden md:flex items-center gap-6">
                <div class="text-right hidden xl:block">
                    <div class="text-[0.6rem] text-gray-400 font-bold uppercase tracking-wider">Sales Support</div>
                    <div class="text-sm font-black text-gray-800 hover:text-secondary transition cursor-pointer">{{
                        company_info.header_phone|default:company_info.phone|default:"+91 123 456 7890" }}</div>
                </div>
                <a href="/contact/"
                    class="bg-secondary text-white px-6 py-2.5 rounded shadow-lg shadow-red-100 hover:shadow-red-200 font-bold text-sm hover:bg-red-700 transition flex items-center gap-2 transform hover:-translate-y-0.5">
                    <span>Get Quote</span> <i class="fas fa-arrow-right text-xs"></i>
                </a>
            </div>

            <!-- Mobile Menu Button -->
            <button @click="mobileMenuOpen = !mobileMenuOpen"
                class="md:hidden text-2xl text-gray-700 hover:text-primary transition p-2">
                <i class="fas" :class="mobileMenuOpen ? 'fa-times' : 'fa-bars'"></i>
            </button>
        </div>

        <!-- Navigation Bar -->
        <nav class="bg-primary text-white hidden md:block border-t border-gray-800 relative z-10 shadow-inner">
            <div class="container mx-auto px-4">
                <ul class="flex">
                    <li><a href="{% url 'home' %}"
                            class="block py-3 px-6 text-sm font-bold uppercase tracking-wider hover:bg-white hover:text-primary transition duration-200 border-r border-gray-700 border-opacity-30">Home</a>
                    </li>

                    <!-- Products Mega Menu Trigger -->
                    <li class="group">
                        <a href="/products/"
                            class="block py-3 px-6 text-sm font-bold uppercase tracking-wider hover:bg-white hover:text-primary transition duration-200 border-r border-gray-700 border-opacity-30 flex items-center gap-1">
                            Products <i class="fas fa-chevron-down text-[10px] opacity-70 mb-0.5"></i>
                        </a>

                        <!-- Mega Menu Dropdown -->
                        <div
                            class="absolute top-full left-0 w-full bg-white text-gray-800 shadow-2xl hidden group-hover:block border-t-4 border-secondary opacity-0 group-hover:opacity-100 transition-opacity duration-200 transform origin-top z-50">
                            <div class="container mx-auto p-8">
                                <div class="grid grid-cols-12 gap-8">
                                    <!-- Sidebar in Menu -->
                                    <div class="col-span-3 bg-gray-50 p-5 rounded border border-gray-100">
                                        <h4
                                            class="font-bold text-gray-900 mb-4 uppercase text-xs tracking-widest border-b border-gray-200 pb-2">
                                            Quick Browse</h4>
                                        <ul class="space-y-3 text-sm font-medium text-gray-600">
                                            <li><a href="/products/?sort=new"
                                                    class="flex items-center justify-between hover:text-secondary group/link"><span
                                                        class="group-hover/link:translate-x-1 transition-transform">New
                                                        Arrivals</span> <i
                                                        class="fas fa-angle-right text-gray-300 opacity-0 group-hover/link:opacity-100"></i></a>
                                            </li>
                                            <li><a href="/products/?featured=true"
                                                    class="flex items-center justify-between hover:text-secondary group/link"><span
                                                        class="group-hover/link:translate-x-1 transition-transform">Featured
                                                        Items</span> <i
                                                        class="fas fa-angle-right text-gray-300 opacity-0 group-hover/link:opacity-100"></i></a>
                                            </li>
                                            <li><a href="/brands/"
                                                    class="flex items-center justify-between hover:text-secondary group/link"><span
                                                        class="group-hover/link:translate-x-1 transition-transform">Top
                                                        Brands</span> <i
                                                        class="fas fa-angle-right text-gray-300 opacity-0 group-hover/link:opacity-100"></i></a>
                                            </li>
                                        </ul>
                                    </div>

                                    <!-- Categories Grid -->
                                    <div class="col-span-9 grid grid-cols-4 gap-x-6 gap-y-8">
                                        {% for category in mega_menu_categories|slice:":8" %}
                                        <div class="break-inside-avoid">
                                            <a href="/products/?category={{ category.slug }}"
                                                class="group/cat block mb-2">
                                                <div class="flex items-center gap-3">
                                                    <div
                                                        class="w-10 h-10 rounded bg-gray-100 flex items-center justify-center text-gray-400 group-hover/cat:bg-secondary group-hover/cat:text-white transition-colors shadow-sm">
                                                        {% if category.image %}
                                                        <img src="{{ category.image.url }}"
                                                            class="w-full h-full object-cover rounded">
                                                        {% else %}
                                                        <i class="fas fa-cube text-sm"></i>
                                                        {% endif %}
                                                    </div>
                                                    <span
                                                        class="font-black text-primary group-hover/cat:text-secondary text-sm uppercase tracking-wide leading-tight">
                                                        {{ category.name }}
                                                    </span>
                                                </div>
                                            </a>
                                            {% if category.children.exists %}
                                            <ul
                                                class="space-y-1.5 pl-14 text-sm text-gray-600 border-l-2 border-gray-100 ml-5 hover:border-secondary transition-colors mt-2">
                                                {% for child in category.children.all|slice:":4" %}
                                                <li>
                                                    <a href="/products/?category={{ child.slug }}"
                                                        class="hover:text-secondary transition-colors block py-0.5 hover:translate-x-1 transform duration-150 font-medium">
                                                        {{ child.name }}
                                                    </a>
                                                </li>
                                                {% endfor %}
                                            </ul>
                                            {% endif %}
                                        </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </li>

                    <li><a href="/brands/"
                            class="block py-3 px-6 text-sm font-bold uppercase tracking-wider hover:bg-white hover:text-primary transition duration-200 border-r border-gray-700 border-opacity-30">Brands</a>
                    </li>
                    <li><a href="/catalogs/"
                            class="block py-3 px-6 text-sm font-bold uppercase tracking-wider hover:bg-white hover:text-primary transition duration-200 border-r border-gray-700 border-opacity-30">Catalogs</a>
                    </li>
                    <li><a href="/about/"
                            class="block py-3 px-6 text-sm font-bold uppercase tracking-wider hover:bg-white hover:text-primary transition duration-200 border-r border-gray-700 border-opacity-30">About
                            Us</a></li>
                    <li><a href="/contact/"
                            class="block py-3 px-6 text-sm font-bold uppercase tracking-wider hover:bg-white hover:text-primary transition duration-200 border-r border-gray-700 border-opacity-30">Contact</a>
                    </li>
                </ul>
            </div>
        </nav>

        <!-- Mobile Menu (Alpine) -->
        <div x-show="mobileMenuOpen" x-transition:enter="transition ease-out duration-200"
            x-transition:enter-start="opacity-0 -translate-y-2" x-transition:enter-end="opacity-100 translate-y-0"
            x-transition:leave="transition ease-in duration-150" x-transition:leave-start="opacity-100 translate-y-0"
            x-transition:leave-end="opacity-0 -translate-y-2"
            class="md:hidden bg-white border-t border-gray-200 shadow-xl absolute w-full left-0 top-full max-h-[80vh] overflow-y-auto">
            <div class="p-4 space-y-4">
                <form action="{% url 'product_list' %}" method="GET" class="relative">
                    <input type="text" name="q" placeholder="Search..."
                        class="w-full border border-gray-300 rounded px-4 py-2 focus:outline-none focus:border-secondary">
                    <button type="submit" class="absolute right-2 top-2 text-gray-500"><i
                            class="fas fa-search"></i></button>
                </form>
                <div class="grid grid-cols-1 gap-2">
                    <a href="{% url 'home' %}"
                        class="block py-2 px-4 bg-gray-50 rounded font-bold text-gray-700 hover:bg-primary hover:text-white">Home</a>
                    <a href="/products/"
                        class="block py-2 px-4 bg-gray-50 rounded font-bold text-gray-700 hover:bg-primary hover:text-white">Products</a>
                    <a href="/catalogs/"
                        class="block py-2 px-4 bg-gray-50 rounded font-bold text-gray-700 hover:bg-primary hover:text-white">Catalogs</a>
                    <a href="/contact/"
                        class="block py-2 px-4 bg-gray-50 rounded font-bold text-gray-700 hover:bg-primary hover:text-white">Contact</a>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <!-- Main Content -->
    <main class="flex-grow bg-white">
        {% if messages %}
        <div class="container mx-auto px-4 mt-4">
            {% for message in messages %}
            <div class="p-4 rounded shadow-md mb-4 {% if message.tags == 'error' %}bg-red-100 text-red-700 border-l-4 border-red-500{% elif message.tags == 'success' %}bg-green-100 text-green-700 border-l-4 border-green-500{% else %}bg-blue-100 text-blue-700 border-l-4 border-blue-500{% endif %} flex justify-between items-center"
                x-data="{ show: true }" x-show="show">
                <span>{{ message }}</span>
                <button @click="show = false" class="text-gray-500 hover:text-gray-700">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            {% endfor %}
        </div>
        {% endif %}
        {% block content %}{% endblock %}
    </main>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-300 pt-10 pb-6 border-t-4 border-secondary">
        <div class="container mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-8">
            <div>
                <h3 class="text-white text-lg font-bold mb-4 uppercase flex items-center gap-2">
                    <div class="w-1 h-6 bg-secondary"></div> {{ company_info.name|default:"Virja Industries" }}
                </h3>
                <p class="text-sm text-gray-400 mb-4 leading-relaxed">{{
                    company_info.footer_description|default:"Leading supplier of industrial safety gear, tools, and
                    machinery. Quality you can trust."|safe }}</p>
                <div class="flex space-x-3">
                    {% if company_info.facebook %}
                    <a href="{{ company_info.facebook }}" target="_blank"
                        class="w-8 h-8 rounded bg-gray-800 flex items-center justify-center hover:bg-secondary transition text-white"><i
                            class="fab fa-facebook-f"></i></a>
                    {% endif %}
                    {% if company_info.linkedin %}
                    <a href="{{ company_info.linkedin }}" target="_blank"
                        class="w-8 h-8 rounded bg-gray-800 flex items-center justify-center hover:bg-secondary transition text-white"><i
                            class="fab fa-linkedin-in"></i></a>
                    {% endif %}
                    {% if company_info.instagram %}
                    <a href="{{ company_info.instagram }}" target="_blank"
                        class="w-8 h-8 rounded bg-gray-800 flex items-center justify-center hover:bg-secondary transition text-white"><i
                            class="fab fa-instagram"></i></a>
                    {% endif %}
                    {% if company_info.twitter %}
                    <a href="{{ company_info.twitter }}" target="_blank"
                        class="w-8 h-8 rounded bg-gray-800 flex items-center justify-center hover:bg-secondary transition text-white"><i
                            class="fab fa-twitter"></i></a>
                    {% endif %}
                    {% if company_info.youtube %}
                    <a href="{{ company_info.youtube }}" target="_blank"
                        class="w-8 h-8 rounded bg-gray-800 flex items-center justify-center hover:bg-secondary transition text-white"><i
                            class="fab fa-youtube"></i></a>
                    {% endif %}
                </div>
            </div>
            <div>
                <h3 class="text-white text-lg font-bold mb-4 uppercase">Quick Links</h3>
                <ul class="space-y-2 text-sm">
                    <li><a href="/products/" class="hover:text-secondary transition flex items-center gap-2"><i
                                class="fas fa-chevron-right text-[10px]"></i> Products</a></li>
                    <li><a href="/catalogs/" class="hover:text-secondary transition flex items-center gap-2"><i
                                class="fas fa-chevron-right text-[10px]"></i> Catalogs</a></li>
                    <li><a href="/contact/" class="hover:text-secondary transition flex items-center gap-2"><i
                                class="fas fa-chevron-right text-[10px]"></i> Contact Us</a></li>
                    <li><a href="/brands/" class="hover:text-secondary transition flex items-center gap-2"><i
                                class="fas fa-chevron-right text-[10px]"></i> Brands</a></li>
                </ul>
            </div>
            <div>
                <h3 class="text-white text-lg font-bold mb-4 uppercase">Contact</h3>
                <ul class="space-y-4 text-sm">
                    <li class="flex items-start">
                        <i class="fas fa-map-marker-alt mt-1 mr-3 text-secondary"></i>
                        <span>{{ company_info.address|default:"Plot 123, Industrial Area,<br>MIDC Bhosari, Pune -
                            411026"|safe }}</span>
                    </li>
                    <li class="flex items-center">
                        <i class="fas fa-phone mr-3 text-secondary"></i>
                        <span>{{ company_info.phone|default:"+91 123 456 7890" }}</span>
                    </li>
                    <li class="flex items-center">
                        <i class="fas fa-envelope mr-3 text-secondary"></i>
                        <span>{{ company_info.email|default:"info@virjaautomation.com" }}</span>
                    </li>
                </ul>
            </div>
            <div>
                <h3 class="text-white text-lg font-bold mb-4 uppercase">Newsletter</h3>
                <form action="{% url 'subscribe_newsletter' %}" method="POST" class="flex flex-col space-y-2">
                    {% csrf_token %}
                    <input type="email" name="email" placeholder="Your email address" required
                        class="px-4 py-2.5 rounded bg-gray-800 border border-gray-700 text-white focus:outline-none focus:border-secondary transition placeholder-gray-500">
                    <button type="submit"
                        class="bg-secondary text-white py-2.5 rounded font-bold hover:bg-red-700 transition shadow-lg">Subscribe</button>
                    <p class="text-[10px] text-gray-500 mt-2">No spam, unsubscribe anytime.</p>
                </form>
            </div>
        </div>
        <div
            class="border-t border-gray-800 mt-10 pt-6 text-center text-xs text-gray-500 flex justify-between container mx-auto px-4">
            <span>&copy; {% now "Y" %} {{ company_info.name|default:"Virja Automation Pvt. Ltd." }}. All rights
                reserved.</span>
            <div class="space-x-4">
                <a href="#" class="hover:text-white">Privacy Policy</a>
                <a href="#" class="hover:text-white">Terms of Service</a>
            </div>
        </div>
    </footer>
</body>

</html>